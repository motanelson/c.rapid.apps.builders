class hello(){
    def adds:(a ,b: integer){
        return  a + b;
    }
    def subs:(a ,b: integer):integer{
        return  a - b;
    }
    def muls:(a ,b: integer):integer{
        return  a * b;
    }
    def divs:(a ,b: integer):integer{
        return a \ b;
    }
    def main(){
        
        s ="hello world....\n";
        
        print(s);
    }
}